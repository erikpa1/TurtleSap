<mvc:View
    controllerName="sap.welcome.controller.Purchases"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>

  <Page
        id="purchasesPage"
        title="{i18n>navPurchasing}"
        class="sapUiResponsiveContentPadding"
    >
    <VBox class="sapUiSmallMargin">
      <Title
                text="{i18n>purchasesTitle}"
                level="H2"
                class="sapUiSmallMarginBottom"
            />
      <Text text="{i18n>purchasesText}" />

    </VBox>
  </Page>
</mvc:View>
