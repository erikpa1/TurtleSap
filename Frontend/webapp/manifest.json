{
  "_version": "1.60.0",
  "sap.app": {
    "id": "sap.welcome",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "sap.welcome.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.tnt": {},
        "sap.ui.core": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.welcome.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "sap.welcome.view",
        "controlId": "pageContainer",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        { "name": "home", "pattern": "", "target": "home" },
        { "name": "info", "pattern": "info", "target": "info" },
        { "name": "settings", "pattern": "settings", "target": "settings" }
      ],
      "targets": {
        "home": { "viewName": "Home" },
        "info": { "viewName": "Info" },
        "settings": { "viewName": "Settings" }
      }
    }
  }
}
